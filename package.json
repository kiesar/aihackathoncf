{
  "name": "hackathoncf",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=25.2.1"
  },
  "scripts": {
    "build": "npm run clean:cache && cross-env SKIP_BUILD_CHECK=true NODE_ENV=production next build",
    "dev": "next dev",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "clean:cache": "node -e \"require('fs').rmSync('.next/dev', {recursive: true, force: true}); require('fs').rmSync('.next/.turbopack', {recursive: true, force: true}); require('fs').rmSync('.next/cache', {recursive: true, force: true});\"",
    "start": "next start",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "agents": "^0.14.5",
    "bcrypt": "^6.0.0",
    "govuk-frontend": "^5.4.0",
    "iron-session": "^8.0.0",
    "next": "^16.2.7",
    "pdf-parse": "^2.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.1",
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/uuid": "^9.0.0",
    "cross-env": "^7.0.3",
    "fast-check": "^4.6.0",
    "sass": "^1.77.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}